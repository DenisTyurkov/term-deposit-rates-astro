---
// Visible FAQ block. Render the SAME FaqItem[] that the page passes to
// faqSchema() so the JSON-LD matches the on-page text (required for FAQ rich
// results). Heading is configurable; defaults suit most pages.
import type { FaqItem } from "../lib/schema";

interface Props {
  items: FaqItem[];
  heading?: string;
}
const { items, heading = "Frequently Asked Questions" } = Astro.props;
---
{
  items.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 py-12">
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-8">
        <h2 class="text-3xl font-bold text-gray-900 mb-6">{heading}</h2>
        <div class="divide-y divide-gray-200">
          {items.map((item) => (
            <div class="py-5 first:pt-0 last:pb-0">
              <h3 class="text-lg font-semibold text-gray-900 mb-2">{item.question}</h3>
              <p class="text-gray-600 leading-relaxed">{item.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
