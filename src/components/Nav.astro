---
// Port of layouts/_nav.html.erb
// "Banks" is a pure-HTML/CSS <details> dropdown (no client JS — keeps the
// calculator as the only island). Bank list is sourced from allProviders()
// so it stays in sync with the data layer.
import { allProviders } from "../lib/rates";
const banks = allProviders();
---
<nav class="bg-white border-b border-gray-200 px-4 py-3">
  <div class="max-w-7xl mx-auto flex justify-between items-center">
    <div class="flex items-center">
      <a href="/" class="flex items-center text-xl font-bold text-gray-900 hover:text-blue-600">
        <img src="/favicon-32x32.png" alt="Term Deposit Rates" style="width: 16px; height: 16px; margin-right: 8px;" />
        Term Deposit Rates
      </a>
    </div>

    <div class="flex items-center gap-x-4 gap-y-1 flex-wrap justify-end text-sm">
      <details class="relative group">
        <summary class="flex items-center gap-1 cursor-pointer list-none text-gray-700 hover:text-blue-600 font-medium [&::-webkit-details-marker]:hidden">
          Banks
          <svg class="w-3.5 h-3.5 transition-transform group-open:rotate-180" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.06l3.71-3.83a.75.75 0 111.08 1.04l-4.25 4.39a.75.75 0 01-1.08 0L5.21 8.27a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
          </svg>
        </summary>
        <div class="absolute right-0 mt-2 w-56 max-h-[70vh] overflow-y-auto bg-white border border-gray-200 rounded-lg shadow-lg z-20 p-2">
          <a href="/" class="block px-3 py-2 rounded-md text-gray-700 hover:bg-blue-50 hover:text-blue-700 font-medium">All bank rates</a>
          <div class="my-1 border-t border-gray-100"></div>
          {banks.map((b) => (
            <a href={`/${b.slug}`} class="block px-3 py-2 rounded-md text-gray-700 hover:bg-blue-50 hover:text-blue-700">{b.name}</a>
          ))}
        </div>
      </details>
      <a href="/short-term-deposit-rates" class="text-gray-700 hover:text-blue-600 font-medium">Short-Term</a>
      <a href="/long-term-deposit-rates" class="text-gray-700 hover:text-blue-600 font-medium">Long-Term</a>
      <a href="/term-deposit-rates-for-seniors" class="text-gray-700 hover:text-blue-600 font-medium">Seniors</a>
      <a href="/pie-term-deposit-rates" class="text-gray-700 hover:text-blue-600 font-medium">PIE</a>
      <a href="/term-deposit-calculator" class="text-gray-700 hover:text-blue-600 font-medium">Calculator</a>
    </div>
  </div>
</nav>
