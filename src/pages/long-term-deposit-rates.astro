---
import { getEntry, render } from "astro:content";
import Layout from "../layouts/Layout.astro";
import BankLogoStrip from "../components/BankLogoStrip.astro";
import SummaryCards from "../components/SummaryCards.astro";
import RatesMatrix from "../components/RatesMatrix.astro";
import Faq from "../components/Faq.astro";
import RelatedLinks from "../components/RelatedLinks.astro";
import { matrixPageData, logoStripParents } from "../lib/rates";
import { monthYearShort } from "../lib/format";
import { collectionPageSchema, itemListSchema, faqSchema, ROOT_URL } from "../lib/schema";
import { longTermFaqItems } from "../lib/faq";

const LONG_TERMS = ["18 mths", "2 years", "3 years", "4 years", "5 years"];
const data = matrixPageData({ rateType: "regular", termLengths: LONG_TERMS });
const parents = logoStripParents(data.rates);

const pageUrl = `${ROOT_URL}/long-term-deposit-rates/`;
const title = `Best Long-Term Deposit Rates NZ ${data.latestScrapeAt ? monthYearShort(data.latestScrapeAt) : ""} — 1 to 5 Years`;
const description =
  "Compare the best long-term deposit (fixed deposit) rates from 1 to 5 years across major New Zealand banks. Lock in today's rate for extended investment terms. Updated daily.";

const faqItems = longTermFaqItems();

const jsonLd = [
  collectionPageSchema(
    "Long-Term Deposit Rates New Zealand",
    "Compare long-term deposit rates (18+ months) from major New Zealand banks",
    pageUrl,
    data.latestScrapeAt
  ),
  itemListSchema(data.rates, "Long-Term Term Deposit Rates", pageUrl),
  faqSchema(faqItems),
];
const breadcrumbs = [
  { name: "Home", url: `${ROOT_URL}/` },
  { name: "Long-Term Rates", url: pageUrl },
];

const entry = await getEntry("pages", "long-term-deposit-rates");
const Content = entry ? (await render(entry)).Content : null;
---
<Layout title={title} description={description} jsonLd={jsonLd} breadcrumbs={breadcrumbs}>
  <div class="bg-white">
    <div class="max-w-7xl mx-auto px-4 py-8">
      <div class="text-center mb-8">
        <h1 class="text-4xl font-bold text-gray-900 mb-4">Long-Term Deposit Rates New Zealand</h1>
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          Compare long-term deposit rates (18+ months) from major New Zealand banks.
          Ideal for maximizing returns on extended investment terms and long-term goals.
        </p>
      </div>
      <BankLogoStrip parents={parents} />
    </div>
  </div>

  <SummaryCards cards={data.summaryCards} latestScrapeAt={data.latestScrapeAt} />

  <RatesMatrix
    heading="Long-Term Rates (18+ Months)"
    banks={data.banks}
    terms={data.terms}
    matrix={data.matrix}
    bestRates={data.bestRates}
    latestScrapeAt={data.latestScrapeAt}
  />

  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-8">
      <div class="prose prose-gray max-w-none">
        {Content && <Content />}
      </div>
    </div>
  </div>

  <Faq items={faqItems} heading="Long-Term Deposit FAQs" />

  <RelatedLinks exclude="/long-term-deposit-rates" />
</Layout>
